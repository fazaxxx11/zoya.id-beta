# =====================================================
# zoya.id — Environment Variables
# Copy file ini ke .env (jangan commit, sudah di .gitignore)
# =====================================================

# --- Beta Mode (frontend) ---
# true  = semua tools inti GRATIS selama beta (login tetap wajib),
#         pricing/paywall/top-up disembunyikan dengan label "Coming Soon".
# false = pricing & paywall aktif seperti biasa.
# Default: true (kosong = true).
VITE_BETA_FREE=true

# --- Branding (frontend) ---
VITE_BRAND_NAME=zoya.id
VITE_BRAND_TAGLINE=AI Tools for Research & Education

# --- Admin Access (frontend) ---
# Admin role sekarang menggunakan Supabase profiles.role = 'admin'
# Bukan password-based lagi. Set role via Supabase dashboard.
VITE_ADMIN_EMAIL=admin@zoya.id

# --- Supabase (frontend, public-safe) ---
# Dapatkan di: https://supabase.com/dashboard/project/<project>/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# --- Supabase (backend) ---
# Backend perlu SUPABASE_URL untuk verifikasi JWT
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# --- Supabase Service Role (backend ONLY, JANGAN expose ke client!) ---
# Dipakai untuk webhook Midtrans & insert assessments dari server
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --- AI Providers (backend) ---
# Primary: General Compute (DeepSeek V3.2)
GENERALCOMPUTE_API_KEY=gc_your_generalcompute_key
# Fallback: Groq (gratis)
GROQ_API_KEY=gsk_your_groq_key
# Optional fallback: https://platform.moonshot.ai
KIMI_API_KEY=

# --- Midtrans Payment Gateway (backend) ---
# Sandbox: https://dashboard.sandbox.midtrans.com/settings/config_info
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxx
MIDTRANS_IS_PRODUCTION=false

# --- Upstash Redis (rate limiting) ---
# Free tier: https://upstash.com — 10k commands/day
# Tanpa ini, rate limit fallback ke in-memory (tidak persistent, tapi cukup untuk MVP)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Kill Switches ---
# Set to 'false' to disable features without redeploy
AI_ENABLED=true
PAYMENTS_ENABLED=true
REGISTRATION_ENABLED=true

# --- Server ---
PORT=3000