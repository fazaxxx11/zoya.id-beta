# =====================================================
# zoya.id — Environment Variables
# Copy file ini ke .env (jangan commit, sudah di .gitignore)
# =====================================================

# --- Beta Mode (frontend) ---
# true  = semua tools inti GRATIS selama beta (login tetap wajib),
#         pricing/paywall/top-up disembunyikan dengan label "Coming Soon".
# false = pricing & paywall aktif seperti biasa.
# Default: true (kosong = true).
VITE_BETA_FREE=true

# --- Branding (frontend) ---
VITE_BRAND_NAME=zoya.id
VITE_BRAND_TAGLINE=AI Tools for Research & Education

# --- Admin Access (frontend) ---
# Admin role sekarang menggunakan Supabase profiles.role = 'admin'
# Bukan password-based lagi. Set role via Supabase dashboard.
VITE_ADMIN_EMAIL=admin@zoya.id

# --- Supabase (frontend, public-safe) ---
# Dapatkan di: https://supabase.com/dashboard/project/<project>/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# --- Supabase (backend) ---
# Backend perlu SUPABASE_URL untuk verifikasi JWT
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# --- Supabase Service Role (backend ONLY, JANGAN expose ke client!) ---
# Dipakai untuk webhook Midtrans & insert assessments dari server
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --- AI Providers (backend) ---
# Primary: General Compute (DeepSeek V3.2)
# --- AI1833 (primary coder) ---
AI1833_API_KEY=sk_your_ai1833_key
# AI1833_URL=https://api.ai1833.shop/v1/chat/completions
# AI1833_BASE_URL=https://api.ai1833.shop/v1/chat/completions
# AI1833_MODEL=deepseek-v4-flash

GENERALCOMPUTE_API_KEY=gc_your_generalcompute_key
# Fallback: Groq (gratis)
GROQ_API_KEY=gsk_your_groq_key
# Optional fallback: https://platform.moonshot.ai
KIMI_API_KEY=
# Optional: OpenRouter (multi-model)
OPENROUTER_API_KEY=

# --- AI Provider URL/Model Overrides (optional) ---
# Override default URLs (biasanya tidak perlu diubah)
# GENERALCOMPUTE_URL=https://api.generalcompute.com/v1/chat/completions
# GENERALCOMPUTE_BASE_URL=https://api.generalcompute.com/v1/chat/completions
# GROQ_URL=https://api.groq.com/openai/v1/chat/completions
# GROQ_BASE_URL=https://api.groq.com/openai/v1/chat/completions
# KIMI_URL=https://api.moonshot.ai/v1/chat/completions
# KIMI_BASE_URL=https://api.moonshot.ai/v1/chat/completions
# OPENROUTER_URL=https://openrouter.ai/api/v1/chat/completions
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions

# Override default models
# GENERALCOMPUTE_MODEL=deepseek-v3.2
# GROQ_MODEL=llama-3.3-70b-versatile
# KIMI_MODEL=moonshot-v1-8k
# OPENROUTER_MODEL=openrouter/auto

# --- Midtrans Payment Gateway (backend) ---
# Sandbox: https://dashboard.sandbox.midtrans.com/settings/config_info
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxx
MIDTRANS_IS_PRODUCTION=false

# --- Upstash Redis (rate limiting) ---
# Free tier: https://upstash.com — 10k commands/day
# Tanpa ini, rate limit fallback ke in-memory degraded (stricter limits)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Rate Limiting (backend) ---
# Default values — sesuaikan sesuai kebutuhan
RATE_LIMIT_USER_MAX=20          # Max requests per user per window
RATE_LIMIT_IP_MAX=40            # Max requests per IP per window
RATE_LIMIT_WINDOW_MS=60000      # Window duration in ms (60s)
RATE_LIMIT_FAIL_CLOSED=false    # true = reject semua saat Redis down (strict mode)

# --- CORS (backend) ---
# Comma-separated allowed origins (exact match)
# Default: https://zoya.id,https://www.zoya.id,https://zoya-id-beta.vercel.app
# ALLOWED_ORIGINS=https://zoya.id,https://www.zoya.id,https://zoya-id-beta.vercel.app

# --- Kill Switches ---
# Set to 'false' to disable features without redeploy
AI_ENABLED=true
PAYMENTS_ENABLED=true
REGISTRATION_ENABLED=true

# --- Server ---
PORT=3000
